# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo servidor (Railway). Settings → API → service_role — activa cuentas sin depender del correo.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_WEB_API_URL=https://your-app.up.railway.app

# URL pública de la web en Railway (sin barra final)
NEXT_PUBLIC_APP_URL=https://uteq-seguridad.up.railway.app

# Google Maps (Maps JavaScript API) — misma key que móvil si aplica
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Dominio institucional
UTEQ_EMAIL_DOMAIN=uteq.edu.mx

# Notificaciones — Brevo (correos de auth y alertas en Railway)
# API key: Brevo → SMTP & API → API Keys (debe empezar con xkeysib-)
BREVO_API_KEY=
# Remitente VERIFICADO en Brevo → Senders (debe coincidir exactamente)
BREVO_FROM_EMAIL=alertas@uteq.edu.mx
BREVO_FROM_NAME=HERMES UTEQ
# Secreto opcional para POST /api/email/test (header x-email-test-secret)
EMAIL_TEST_SECRET=
# 3) SMTP (opcional): para Supabase → Authentication → SMTP Settings
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=

# WhatsApp SOS — Meta Cloud API (solo botón SOS/pánico; mensajes salientes, sin chat)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Plantilla: usa hello_world para probar (llega como el test de Meta).
# Cuando hermes_sos_alerta esté Approved, cámbiala y WHATSAPP_TEMPLATE_LANG=es_MX
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANG=en_US
# Texto libre casi no se entrega; preferir siempre plantilla
WHATSAPP_ALLOW_TEXT=false

# Push — Firebase Cloud Messaging (FCM HTTP v1 en Railway)
# Crea un proyecto en Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Flutter — Firebase client (Project settings → Your apps → Android)
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
